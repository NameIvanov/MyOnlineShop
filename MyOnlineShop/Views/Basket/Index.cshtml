@model List<Basket>
@{
    ViewData["Title"] = "Product Page";
}

<div class="row justify-content-evenly">

    @if (Model != null && Model.Count > 0)
    {
        <div class="col-9">
            <table class="table table-responsive table-striped table-hover mb-5">
                <thead>
                    <tr align="center">
                        <th scope="col">#</th>
                        <th scope="col">Наименование товара</th>
                        <th scope="col">Цена, руб.</th>
                        <th scope="col">Количество, шт.</th>
                        <th scope="col">Стоимость, руб.</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Count; i++)
                    {
                        <tr align="center">
                            <td class="fw-bold">@(i+1)</td>
                            <td align="left">"@(Model[i].NameProduct)"</td>
                            <td align="left">@(Model[i].CostProduct)</td>
                            <td>
                                <a class="btn btn-success me-2"
                                   asp-controller="Basket"
                                   asp-action="Minus"
                                   asp-route-id="@Model[i].Id">
                                    -
                                </a>
                                @(Model[i].CountProduct)
                                <a class="btn btn-success ms-2"
                                   asp-controller="Basket"
                                   asp-action="Plus"
                                   asp-route-id="@Model[i].Id">
                                    +
                                </a>
                            </td>
                            <td class="fw-bold">@(Model[i].CostProduct * Model[i].CountProduct)</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr align="center">
                        <th colspan="2"></th>
                        <th colspan="2">
                            Общая стоимость: @Model.Sum(p => p.CostProduct * p.CountProduct)
                        </th>
                        <th colspan="1">
                            <a class="btn btn-success"
                               asp-controller="Basket"
                               asp-action="PlaceOrder">
                                Оформить заказ
                            </a>
                        </th>
                        <th colspan="1">
                            <a class="btn btn-success"
                               asp-controller="Basket"
                               asp-action="Delete">
                                Очистить корзину
                            </a>
                        </th>
                    </tr>
                </tfoot>
            </table>

        </div>
    }
    else
    {
        <div class="col-auto m-5">
            <h2 class="row-title">В корзине нет товаров!</h2>
        </div>

    }
</div>
